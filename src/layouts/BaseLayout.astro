---
import LayoutEnhancements from '../components/LayoutEnhancements.astro';
import SocialIcon from '../components/SocialIcon.astro';
import '../styles/global.css';
import type { NavItem, SiteGlobalData } from '../lib/content';

interface Props {
  site: SiteGlobalData;
  title?: string;
  description?: string;
  fancyNavbar?: boolean;
  navItems?: NavItem[];
}

const {
  site,
  title = 'Matthew Brunetti',
  description = 'Personal website of Matthew Brunetti.',
  fancyNavbar = false,
  navItems = [],
} = Astro.props;

function hexToRgbString(hex: string) {
  const normalized = hex.replace('#', '').slice(0, 6);
  const safeHex = normalized.padEnd(6, '0');
  const parts = safeHex.match(/.{1,2}/g) ?? ['00', '00', '00'];

  return parts.map((part) => Number.parseInt(part, 16)).join(', ');
}

const themePrimary = site.theme.primary;
const themePrimaryRgb = hexToRgbString(themePrimary);
const pageTitle = title === site.siteTitle ? title : `${title} | ${site.siteTitle}`;
const isHomePage = Astro.url.pathname === '/';
const navClassName = [
  'navcontainer',
  'navcontainer-scrolledtotop',
  fancyNavbar ? 'navcontainer-fancy' : '',
]
  .filter(Boolean)
  .join(' ');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style={`--theme-color-primary: ${themePrimary}; --theme-color-primary-rgb: ${themePrimaryRgb};`}>
    <div id="loader" class="show">
      <div class="loader"></div>
    </div>
    <div id="top" class="main-wrapper">
      <div class={navClassName}>
        <header class="navbar-shell">
          <nav class="navbar navbar-light">
            <div class="container-fluid navbar-inner">
              <a href="/" class="navbar-brand">{site.siteTitle}</a>
              {navItems.length > 0 && (
                <>
                  <button
                    type="button"
                    class="navbar-toggler"
                    data-nav-toggle
                    aria-controls="navbarCollapse"
                    aria-expanded="false"
                    aria-label="Toggle navigation"
                  >
                    <span class="navbar-toggler-icon"></span>
                  </button>
                  <div class="navbar-collapse collapse justify-content-between" id="navbarCollapse" data-nav-collapse>
                    <div class="navbar-nav ml-auto" aria-label="Primary">
                      {navItems.map((item) => (
                        <a href={item.href} class="nav-item nav-link">
                          {item.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </>
              )}
            </div>
          </nav>
        </header>
      </div>

      <main>
        <slot />
      </main>
    </div>

    <footer class="footer">
      <div class="container-fluid">
        <div class="container">
          <div class="footer-info">
            <h2>{site.person.name}</h2>
            <h3>{site.person.title}</h3>
            <div class="footer-menu">
              <p><a href={`tel:${site.person.phone}`}>{site.person.phone}</a></p>
              <p><a href={`mailto:${site.person.email}`}>{site.person.email}</a></p>
            </div>
            {site.social.length > 0 && (
              <div class="footer-social" aria-label="Social links">
                {site.social.map((item) => (
                  <a href={item.url} target="_blank" rel="noreferrer" aria-label={item.platform}>
                    <SocialIcon platform={item.platform} />
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
        <div class="container copyright">
          <p>
            &copy; {site.person.name}, All Right Reserved | Design created by{' '}
            <a href="https://htmlcodex.com" target="_blank" rel="noreferrer">HTML Codex</a> & customized by
            Matthew Brunetti
          </p>
        </div>
      </div>
    </footer>

    <a class="btn back-to-top" href="#top" aria-label="Back to top">
      <span aria-hidden="true">^</span>
    </a>
    <LayoutEnhancements isHomePage={isHomePage} />
  </body>
</html>
