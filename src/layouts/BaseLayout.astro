---
import '../styles/global.css';
import type { NavItem, SiteGlobalData } from '../lib/content';

interface Props {
  site: SiteGlobalData;
  title?: string;
  description?: string;
  fancyNavbar?: boolean;
  navItems?: NavItem[];
  isHomePage?: boolean;
}

const {
  site,
  title = 'Matthew Brunetti',
  description = 'Personal website of Matthew Brunetti.',
  fancyNavbar = false,
  navItems = [],
  isHomePage = false,
} = Astro.props;

function hexToRgbString(hex: string) {
  const normalized = hex.replace('#', '').slice(0, 6);
  const safeHex = normalized.padEnd(6, '0');
  const parts = safeHex.match(/.{1,2}/g) ?? ['00', '00', '00'];

  return parts.map((part) => Number.parseInt(part, 16)).join(', ');
}

const themePrimary = site.theme.primary;
const themePrimaryRgb = hexToRgbString(themePrimary);
const pageTitle = title === site.siteTitle ? title : `${title} | ${site.siteTitle}`;
const navClassName = [
  'navcontainer',
  'navcontainer-scrolledtotop',
  fancyNavbar ? 'navcontainer-fancy' : '',
]
  .filter(Boolean)
  .join(' ');

const socialIconMap: Record<string, string> = {
  GitHub: 'github',
  LinkedIn: 'linkedin-in',
  Twitter: 'twitter',
  Facebook: 'facebook-f',
  Instagram: 'instagram',
  YouTube: 'youtube',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@5.15.4/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/animate.css@4.1.1/animate.compat.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/owl.carousel@2.3.4/dist/assets/owl.carousel.min.css" rel="stylesheet" />
  </head>
  <body style={`--theme-color-primary: ${themePrimary}; --theme-color-primary-rgb: ${themePrimaryRgb};`}>
    <div id="loader" class="show">
      <div class="loader"></div>
    </div>

    <div id="top" class="main-wrapper">
      <div class={navClassName}>
        <div class="navbar navbar-expand-lg bg-light navbar-light">
          <div class="container-fluid">
            <a href="/" class="navbar-brand">{site.siteTitle}</a>
            <button
              type="button"
              class="navbar-toggler"
              data-toggle="collapse"
              data-target="#navbarCollapse"
              aria-controls="navbarCollapse"
              aria-expanded="false"
              aria-label="Toggle navigation"
            >
              <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
              {navItems.length > 0 && (
                <div class="navbar-nav ml-auto" aria-label="Primary">
                  {navItems.map((item) => (
                    <a href={item.href} class="nav-item nav-link">
                      {item.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </div>

      <main>
        <slot />
      </main>
    </div>

    <footer class="footer">
      <div class="container-fluid">
        <div class="container">
          <div class="footer-info">
            <h2>{site.person.name}</h2>
            <h3>{site.person.title}</h3>
            <div class="footer-menu">
              <p>
                <a href={`tel:${site.person.phone}`}>{site.person.phone}</a>
              </p>
              <p>
                <a href={`mailto:${site.person.email}`}>{site.person.email}</a>
              </p>
            </div>
            {site.social.length > 0 && (
              <div class="footer-social" aria-label="Social links">
                {site.social.map((item) => (
                  <a href={item.url} target="_blank" rel="noreferrer" aria-label={item.platform}>
                    <i class={`fab fa-${socialIconMap[item.platform] ?? 'link'}`}></i>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
        <div class="container copyright">
          <p>
            &copy; {site.person.name}, All Right Reserved | Design created by <a href="https://htmlcodex.com">HTML Codex</a>
            {' '} & customized by Matthew Brunetti
          </p>
        </div>
      </div>
    </footer>

    <a class="btn back-to-top" href="#"><i class="fa fa-chevron-up"></i></a>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/js/bootstrap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery.easing@1.4.1/jquery.easing.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/wow.js@1.2.2/dist/wow.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/waypoints@4.0.1/lib/jquery.waypoints.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12/lib/typed.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/owl.carousel@2.3.4/dist/owl.carousel.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/isotope-layout@3.0.6/dist/isotope.pkgd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tilt.js@1.2.1/dest/tilt.jquery.min.js"></script>
    <script is:inline define:vars={{ isHomePage }}>
      window.isLayout = true;
      window.isEdit = false;

      (function () {
        const main = function () {
          if (!window.isLayout || !window.jQuery) return;
          const $ = window.jQuery;

          if (window.WOW) {
            new window.WOW().init();
          }

          $(document).ready(function () {
            window.setTimeout(function () {
              $('#loader').removeClass('show');
            }, 100);
          });

          $(window).scroll(function () {
            const isAtTop = $(this).scrollTop() <= 50;
            $('.back-to-top')[isAtTop ? 'fadeOut' : 'fadeIn']('slow');
          });

          $('.back-to-top').click(function () {
            $('html, body').animate({ scrollTop: 0 }, 1000, 'easeOutBounce');
            return false;
          });

          const setNavContainerScrolledToTop = function () {
            $('.navcontainer').toggleClass('navcontainer-scrolledtotop', $('html').scrollTop() === 0);
          };

          $(window).scroll(setNavContainerScrolledToTop);
          $(document).ready(setNavContainerScrolledToTop);

          $('.block-typed-text-widget').each(function () {
            const element = this;
            $(element).empty();
            const tag = element.dataset.widgetTag || 'h2';
            const $child = $(`<${tag} style="display: inline-block" />`);
            $child.appendTo(element);
            new window.Typed($child.get(0), {
              strings: (element.dataset.widgetText || '').split(','),
              typeSpeed: 100,
              backSpeed: 20,
              smartBackspace: false,
              loop: true,
            });
            const $cursor = $(element).find('.typed-cursor');
            const updateCursorStyles = function () {
              for (const prop of ['display', 'font-size', 'line-height', 'margin-top', 'margin-bottom']) {
                $cursor.css(prop, $child.css(prop));
              }
            };
            updateCursorStyles();
            $(window).resize(updateCursorStyles);
          });

          $('.block-percentages-widget').each(function () {
            const element = this;
            $(element).waypoint(
              function () {
                $(element)
                  .find('.progress-bar')
                  .each(function () {
                    $(this).css('width', $(this).attr('aria-valuenow') + '%');
                  });
              },
              { offset: '80%' },
            );
          });

          $('.hero-image .bp-image-widget').tilt?.({ maxTilt: 8, scale: 1.02 });

          if (isHomePage) {
            const baseTitle = window.document.title;
            const updateState = function (hash) {
              window.history.replaceState({}, '', hash);
              const title = $(`.navbar a.nav-item[href="${hash}"]`).text();
              window.document.title = title ? `${title} | ${baseTitle}` : baseTitle;
            };

            const scrollTo = function (element) {
              const offset = $(element).offset();
              if (!offset) return;
              const scrollTop = Math.max(offset.top, 0);
              $('html, body').animate({ scrollTop }, 1000, 'easeOutCubic');
            };

            let hash = window.location.hash;
            if ($(`.navbar a.nav-item[href="${hash}"]`).length === 0) {
              hash = $('.navbar a.nav-item[href]').attr('href');
            }
            $(document).ready(function () {
              updateState(hash);
              scrollTo(hash);
            });

            $('body').scrollspy({ target: '.navbar', offset: 100 });
            $(window).on('activate.bs.scrollspy', function () {
              updateState($('.navbar a.nav-item.active').attr('href'));
            });

            $('.navbar .navbar-nav a').on('click', function (event) {
              event.preventDefault();
              scrollTo(this.hash);
              $('.navbar .navbar-collapse').collapse('hide');
            });
          } else {
            const rootPathPart = window.location.pathname.split('/')[1];
            $('.navbar a.nav-item').each(function () {
              $(this).toggleClass('active', this.hash.slice(1) === rootPathPart);
            });
          }
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', main, { once: true });
        } else {
          main();
        }
      })();
    </script>
  </body>
</html>
