<script is:inline>
  const initRevealAnimations = () => {
    const nodes = document.querySelectorAll('[data-reveal]');
    if (nodes.length === 0) {
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting || !(entry.target instanceof HTMLElement)) {
            return;
          }

          const delay = Number(entry.target.dataset.revealDelay || 0);
          window.setTimeout(() => {
            entry.target.classList.add('is-visible');
          }, delay);
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -10% 0px' },
    );

    nodes.forEach((node) => {
      if (node instanceof HTMLElement) {
        observer.observe(node);
      }
    });
  };

  const initHeroTilt = () => {
    document.querySelectorAll('[data-tilt-card]').forEach((card) => {
      if (!(card instanceof HTMLElement)) {
        return;
      }

      const reset = () => {
        card.style.setProperty('--tilt-rotate-x', '0deg');
        card.style.setProperty('--tilt-rotate-y', '0deg');
        card.style.setProperty('--tilt-scale', '1');
      };

      reset();

      card.addEventListener('mousemove', (event) => {
        const bounds = card.getBoundingClientRect();
        const x = ((event.clientX - bounds.left) / bounds.width - 0.5) * 2;
        const y = ((event.clientY - bounds.top) / bounds.height - 0.5) * 2;
        card.style.setProperty('--tilt-rotate-x', `${-y * 8}deg`);
        card.style.setProperty('--tilt-rotate-y', `${x * 8}deg`);
        card.style.setProperty('--tilt-scale', '1.02');
      });

      card.addEventListener('mouseleave', reset);
      card.addEventListener('mouseenter', () => {
        card.style.setProperty('--tilt-scale', '1.02');
      });
    });
  };

  const initTypedText = () => {
    document.querySelectorAll('.block-typed-text-widget').forEach((element) => {
      if (!(element instanceof HTMLElement) || element.dataset.ready === 'true') {
        return;
      }

      const valueElement = element.querySelector('[data-typed-value]');
      if (!(valueElement instanceof HTMLElement)) {
        return;
      }

      let items;
      try {
        items = JSON.parse(element.dataset.typedItems || '[]');
      } catch {
        items = [];
      }

      if (!Array.isArray(items) || items.length === 0) {
        return;
      }

      element.dataset.ready = 'true';

      const cursor = document.createElement('span');
      cursor.className = 'typed-cursor';
      cursor.setAttribute('aria-hidden', 'true');
      cursor.textContent = '|';
      valueElement.insertAdjacentElement('afterend', cursor);

      let itemIndex = 0;
      let charIndex = items[0].length;
      let deleting = false;

      const tick = () => {
        const current = String(items[itemIndex] || '');

        if (!deleting) {
          charIndex = Math.min(current.length, charIndex + 1);
          valueElement.textContent = current.slice(0, charIndex);

          if (charIndex === current.length) {
            deleting = true;
            window.setTimeout(tick, 1400);
            return;
          }

          window.setTimeout(tick, 90);
          return;
        }

        charIndex = Math.max(0, charIndex - 1);
        valueElement.textContent = current.slice(0, charIndex);

        if (charIndex === 0) {
          deleting = false;
          itemIndex = (itemIndex + 1) % items.length;
          window.setTimeout(tick, 260);
          return;
        }

        window.setTimeout(tick, 30);
      };

      window.setTimeout(tick, 1400);
    });
  };

  const initPercentages = () => {
    const blocks = document.querySelectorAll('.block-percentages-widget');
    if (blocks.length === 0) {
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            return;
          }

          const block = entry.target;
          block.querySelectorAll('.progress-bar').forEach((bar) => {
            if (bar instanceof HTMLElement) {
              bar.style.width = `${bar.dataset.progressTarget || '0'}%`;
            }
          });

          observer.unobserve(block);
        });
      },
      { threshold: 0.3 },
    );

    blocks.forEach((block) => observer.observe(block));
  };

  const initHomeEnhancements = () => {
    initRevealAnimations();
    initHeroTilt();
    initTypedText();
    initPercentages();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHomeEnhancements, { once: true });
  } else {
    initHomeEnhancements();
  }
</script>
