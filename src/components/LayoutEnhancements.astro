---
interface Props {
  isHomePage: boolean;
}

const { isHomePage } = Astro.props;
---

<script is:inline define:vars={{ isHomePage }}>
  const setScrolledToTop = () => {
    const navContainer = document.querySelector('.navcontainer');
    if (!(navContainer instanceof HTMLElement)) {
      return;
    }

    navContainer.classList.toggle('navcontainer-scrolledtotop', window.scrollY <= 0);
  };

  const setBackToTopState = () => {
    const button = document.querySelector('.back-to-top');
    if (!(button instanceof HTMLElement)) {
      return;
    }

    button.classList.toggle('is-visible', window.scrollY > 50);
  };

  const initBackToTop = () => {
    const button = document.querySelector('.back-to-top');
    if (!(button instanceof HTMLAnchorElement)) {
      return;
    }

    button.addEventListener('click', (event) => {
      event.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  };

  const initMobileNav = () => {
    const toggle = document.querySelector('[data-nav-toggle]');
    const collapse = document.querySelector('[data-nav-collapse]');
    if (!(toggle instanceof HTMLButtonElement) || !(collapse instanceof HTMLElement)) {
      return;
    }

    const closeMenu = () => {
      collapse.classList.remove('show');
      toggle.setAttribute('aria-expanded', 'false');
    };

    toggle.addEventListener('click', () => {
      const isOpen = collapse.classList.toggle('show');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    collapse.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  };

  const initHomeNav = () => {
    if (!isHomePage) {
      return;
    }

    const navLinks = Array.from(document.querySelectorAll('.navbar a.nav-item[href^="#"]'));
    const sections = navLinks
      .map((link) => {
        if (!(link instanceof HTMLAnchorElement)) {
          return null;
        }

        const target = document.querySelector(link.getAttribute('href') || '');
        return target instanceof HTMLElement ? { link, target } : null;
      })
      .filter(Boolean);

    if (sections.length === 0) {
      return;
    }

    const setActive = (id) => {
      sections.forEach(({ link, target }) => {
        const isActive = target.id === id;
        link.classList.toggle('active', isActive);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visibleEntries = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        if (visibleEntries[0]?.target instanceof HTMLElement) {
          const id = visibleEntries[0].target.id;
          setActive(id);
          window.history.replaceState({}, '', `#${id}`);
        }
      },
      {
        rootMargin: '-20% 0px -55% 0px',
        threshold: [0.1, 0.25, 0.5],
      },
    );

    sections.forEach(({ target, link }) => {
      observer.observe(target);
      link.addEventListener('click', (event) => {
        event.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    if (window.location.hash) {
      const target = document.querySelector(window.location.hash);
      if (target instanceof HTMLElement) {
        requestAnimationFrame(() => target.scrollIntoView({ block: 'start' }));
        setActive(target.id);
        return;
      }
    }

    const firstSection = sections[0]?.target;
    if (firstSection) {
      setActive(firstSection.id);
    }
  };

  const initLoader = () => {
    const loader = document.getElementById('loader');
    if (!(loader instanceof HTMLElement)) {
      return;
    }

    window.setTimeout(() => {
      loader.classList.remove('show');
    }, 100);
  };

  const initLayoutEnhancements = () => {
    setScrolledToTop();
    setBackToTopState();
    initBackToTop();
    initMobileNav();
    initHomeNav();
    initLoader();

    window.addEventListener('scroll', setScrolledToTop, { passive: true });
    window.addEventListener('scroll', setBackToTopState, { passive: true });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLayoutEnhancements, { once: true });
  } else {
    initLayoutEnhancements();
  }
</script>
