---
import type { PercentagesBlock } from '../../lib/content';

interface Props {
  block: PercentagesBlock;
}

const { block } = Astro.props;
---

<div class="block-percentages-widget">
  {block.items.map((item) => (
    <div class="block-percentages-widget__item">
      <div class="block-percentages-widget__text">
        <p>{item.label}</p>
        <p>{item.percentage}%</p>
      </div>
      <div class="block-percentages-widget__bar">
        <div
          class="progress-bar"
          role="progressbar"
          aria-valuenow={item.percentage}
          aria-valuemin="0"
          aria-valuemax="100"
          data-progress-target={item.percentage}
        />
      </div>
    </div>
  ))}
</div>
