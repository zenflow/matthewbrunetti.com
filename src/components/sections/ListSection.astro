---
import type { ListSection } from '../../lib/content';
import BlockRenderer from '../blocks/BlockRenderer.astro';

interface Props {
  section: ListSection;
}

const { section } = Astro.props;
---

<section id={section.anchorId} class="section-list-widget">
  <div class="container">
    <div class="section-header text-center">
      <p>{section.heading}</p>
      <h2>{section.title}</h2>
    </div>
    <div class="row">
      {section.items.map((item, index) => (
        <div class="col-lg-6 wow fadeInUp" data-wow-delay={`${index / 5}s`}>
          <div class="section-list-widget__item">
            <div class="section-list-widget__icon">
              <i class={`fa fa-${item.icon}`}></i>
            </div>
            <div class="section-list-widget__text">
              <h3>{item.title}</h3>
              {item.description.map((block) => (
                <BlockRenderer block={block} />
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
