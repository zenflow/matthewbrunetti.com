---
import type { ListSection } from '../../lib/content';
import ServiceIcon from '../ServiceIcon.astro';
import BlockRenderer from '../blocks/BlockRenderer.astro';

interface Props {
  section: ListSection;
}

const { section } = Astro.props;
---

<section id={section.anchorId} class="section-list-widget">
  <div class="container">
    <div class="section-header text-center" data-reveal="zoom-in">
      <p>{section.heading}</p>
      <h2>{section.title}</h2>
    </div>
    <div class="section-list-widget__grid">
      {section.items.map((item, index) => (
        <div class="section-list-widget__cell" data-reveal="fade-up" data-reveal-delay={String(index * 120)}>
          <div class="section-list-widget__item">
            <div class="section-list-widget__icon">
              <ServiceIcon icon={item.icon} />
            </div>
            <div class="section-list-widget__text">
              <h3>{item.title}</h3>
              {item.description.map((block) => (
                <BlockRenderer block={block} />
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
