---
import type { HeroSection } from '../../lib/content';
import { resolveSiteAssetUrl } from '../../lib/assets/site-assets';
import BlockRenderer from '../blocks/BlockRenderer.astro';

interface Props {
  section: HeroSection;
}

const { section } = Astro.props;
const heroStyle = section.textureImage
  ? `--hero-background-texture: url(${resolveSiteAssetUrl(section.textureImage)});${section.isFixedBackground ? ' background-attachment: fixed;' : ''}`
  : section.isFixedBackground
    ? 'background-attachment: fixed;'
    : undefined;
---

<section id={section.anchorId} class="section-hero-widget" style={heroStyle}>
  <div class="container-fluid">
    <div class="hero-layout">
      <div class="hero-content">
        <div class="hero-text">
          {section.intro.map((block) => (
            <BlockRenderer block={block} />
          ))}
        </div>
      </div>
      <div class="hero-image-column">
        <div class="hero-image">
          {section.image.map((block) => (
            <BlockRenderer block={block} imageClass="hero-photo" imageLoading="eager" />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
