---
import BaseLayout from '../../layouts/BaseLayout.astro';

const navItems = [
  { label: 'Home', href: '/#home' },
  { label: 'About', href: '/#about' },
  { label: 'Services', href: '/#services' },
];
---

<BaseLayout title="Blog" description="Future-ready blog route for matthewbrunetti.com." navItems={navItems}>
  <section class="section-placeholder page-shell">
    <div class="container narrow">
      <div class="section-header">
        <p>Blog</p>
        <h1>Blog route scaffolded</h1>
      </div>
      <p>
        The legacy dump does not currently contain published blog posts, but this route is now reserved for the
        future post architecture.
      </p>
    </div>
  </section>
</BaseLayout>
