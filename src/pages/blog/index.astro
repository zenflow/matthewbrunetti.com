---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getHomeNavItems, getSiteBlog, getSiteGlobal, getSiteHome } from '../../lib/content';

const site = await getSiteGlobal();
const home = await getSiteHome();
const blogPage = await getSiteBlog();
const navItems = getHomeNavItems(home, { includeHomePrefix: true });
---

<BaseLayout site={site} title={blogPage.title} description={blogPage.description} navItems={navItems}>
  <section class="section-placeholder page-shell">
    <div class="container narrow">
      <div class="section-header">
        <p>{blogPage.eyebrow}</p>
        <h1>{blogPage.title}</h1>
      </div>
      <div class="placeholder-grid">
        <article class="placeholder-card">
          <strong>Collection status</strong>
          <p>The `blogPosts` collection is defined and ready for future Markdown or MDX entries.</p>
        </article>
        <article class="placeholder-card">
          <strong>{blogPage.emptyStateTitle}</strong>
          <p>{blogPage.emptyStateBody}</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
