---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeEnhancements from '../components/HomeEnhancements.astro';
import SectionRenderer from '../components/sections/SectionRenderer.astro';
import { getHomeNavItems, getSiteGlobal, getSiteHome } from '../lib/content';

const site = await getSiteGlobal();
const home = await getSiteHome();
const navItems = getHomeNavItems(home);
---

<BaseLayout
  site={site}
  title={site.siteTitle}
  description={home.description}
  fancyNavbar={home.fancyNavbar}
  navItems={navItems}
>
  {home.sections.map((section) => <SectionRenderer section={section} />)}
  <HomeEnhancements />
</BaseLayout>
